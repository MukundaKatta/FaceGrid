# FaceGrid Configuration
# Grid size (number of cells per row/column)
FACEGRID_GRID_SIZE=16

# Minimum skin pixel ratio within a cell to consider it a skin region
FACEGRID_MIN_SKIN_RATIO=0.3

# Score threshold for a candidate region to be classified as face-like
FACEGRID_SCORE_THRESHOLD=0.5

# HSV lower bound for skin detection (H, S, V)
FACEGRID_HSV_LOWER_H=0
FACEGRID_HSV_LOWER_S=30
FACEGRID_HSV_LOWER_V=60

# HSV upper bound for skin detection (H, S, V)
FACEGRID_HSV_UPPER_H=25
FACEGRID_HSV_UPPER_S=180
FACEGRID_HSV_UPPER_V=255

# Minimum region area (in grid cells) to be considered a candidate
FACEGRID_MIN_REGION_AREA=4

# Maximum aspect ratio deviation from 1.0 for face-like regions
FACEGRID_MAX_ASPECT_RATIO=2.0
